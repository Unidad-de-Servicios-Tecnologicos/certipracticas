# Configuración para el proveedor de Inteligencia Artificial (gemini, openai, anthropic)
VITE_AI_PROVIDER=gemini

# API Key de Gemini (Requerido si VITE_AI_PROVIDER=gemini)
#
# ⚠️  AVISO DE SEGURIDAD
# Las variables VITE_* se compilan dentro del bundle JavaScript público.
# Cualquier persona que visite tu app puede extraer esta key con DevTools.
#
# Mitigaciones obligatorias para producción:
#   1) Restringir la key por HTTP referrer en Google Cloud Console:
#      https://console.cloud.google.com/apis/credentials
#      → Edit API key → Application restrictions → HTTP referrers
#      → Añadir: https://tu-dominio.com/*
#   2) Restringir la key a la API "Generative Language" únicamente.
#   3) Configurar cuotas y alertas de presupuesto.
#   4) Rotar la key periódicamente y si sospechas filtración.
#
VITE_GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Modelo de Gemini a utilizar (opcional; por defecto: gemini-2.5-flash)
# Ejemplos: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.5-flash

# Futuras integraciones
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
